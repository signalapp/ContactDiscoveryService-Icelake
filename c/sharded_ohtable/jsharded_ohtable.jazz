from UTIL require "types.jinc"
require "sharded_ohtable.jinc"

// Expose Jasmin-compiled NUM_SHARDS for runtime validation in C
export fn sharded_ohtable_num_shards_const_jazz() -> reg u64 {
  reg u64 r;
  r = (64u)NUM_SHARDS;
  return r;
}

// ---- struct shard layout validators ----

// size_t shard_lb_offset_jazz(void)
export fn shard_lb_offset_jazz() -> reg u64 {
  reg u64 r;
  r = Shard::LB * 8;
  return r;
}

