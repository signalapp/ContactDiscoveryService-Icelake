// ---- algorithmic exports ----

// size_t calculate_batch_size(const sharded_ohtable *table, size_t num_queries, batchable_request requests[])
export
fn calculate_batch_size(
  reg uptr table,
  reg u64 num_queries,
  reg uptr requests
) -> reg u64
{
  reg u64 r;
  #msf reg u64 msf;

  table = table;
  num_queries = num_queries;
  requests = requests;

  msf = #init_msf();
  r = ShardedOHTable::calculate_batch_size(table, num_queries, requests, msf);
  return r;
}

// void prepare_query_batches_query(const sharded_ohtable *table, size_t num_queries,
//   void *all_requests, size_t b, shard_batched_queries *result, size_t *distances)
export
fn prepare_query_batches_query(
  reg uptr table,
  reg u64 num_queries,
  reg uptr all_requests,
  reg u64 b,
  reg uptr result distances
)
{
  #msf reg u64 msf;

  table = table;
  num_queries = num_queries;
  all_requests = all_requests;
  b = b;
  result = result;
  distances = distances;

  msf = #init_msf();
  ShardedOHTable::Query::prepare_query_batches(
    table, num_queries, all_requests, b, result, distances, msf);
}

// void prepare_query_batches_insert(const sharded_ohtable *table, size_t num_queries,
//   void *all_requests, size_t b, shard_batched_queries *result, size_t *distances)
export
fn prepare_query_batches_insert(
  reg uptr table,
  reg u64 num_queries,
  reg uptr all_requests,
  reg u64 b,
  reg uptr result distances
)
{
  #msf reg u64 msf;

  table = table;
  num_queries = num_queries;
  all_requests = all_requests;
  b = b;
  result = result;
  distances = distances;

  msf = #init_msf();
  ShardedOHTable::Insert::prepare_query_batches(
    table, num_queries, all_requests, b, result, distances, msf);
}

// error_t extract_results_from_batch_jazz(shard_batched_queries *sbq, u64 results[],
//   u8 *all_requests, size_t n, size_t *distances)
// NOTE: keeps _jazz suffix to avoid collision with C public API extract_results_from_batch()
export
fn extract_results_from_batch_jazz(
  reg uptr sbq results all_requests,
  reg u64 n,
  reg uptr distances
) -> reg u32
{
  #msf reg u64 msf;
  reg u32 err;

  sbq = sbq;
  results = results;
  all_requests = all_requests;
  n = n;
  distances = distances;

  msf = #init_msf();
  err = ShardedOHTable::Extract::extract_results_from_batch(
    sbq, results, all_requests, n, distances, msf);
  return err;
}
