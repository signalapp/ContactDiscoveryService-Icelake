// error_t oram_get_jazz(oram *oram, u64 block_id, u64 out_data[])
export
fn oram_get_jazz(
  reg uptr oram,
  #secret reg u64 block_id,
  reg uptr out_data
) -> reg u32
{
  #msf reg u64 msf;
  reg u32 abort;
  oram = oram;
  block_id = block_id;
  out_data = out_data;
  msf = #init_msf();
  abort = PathORAM::access(oram, block_id, out_data, msf, PathORAM::READ_ACCESSOR);
  return abort;
}

// error_t oram_put_jazz(oram *oram, u64 block_id, const u64 in_data[])
export
fn oram_put_jazz(
  reg uptr oram,
  #secret reg u64 block_id,
  reg uptr in_data
) -> reg u32
{
  #msf reg u64 msf;
  reg u32 abort;
  oram = oram;
  block_id = block_id;
  in_data = in_data;
  msf = #init_msf();
  abort = PathORAM::access(oram, block_id, in_data, msf, PathORAM::WRITE_ACCESSOR);
  return abort;
}

// error_t oram_function_access_get_jazz(oram *oram, u64 block_id, void *vargs)
export
fn oram_function_access_get_jazz(
  reg uptr oram,
  #secret reg u64 block_id,
  reg uptr vargs
) -> reg u32
{
  #msf reg u64 msf;
  reg u32 abort;
  oram = oram;
  block_id = block_id;
  vargs = vargs;
  msf = #init_msf();
  abort = PathORAM::access(oram, block_id, vargs, msf, PathORAM::RECORD_ACCESSOR);
  return abort;
}

// error_t oram_function_access_put_jazz(oram *oram, u64 block_id, void *vargs)
export
fn oram_function_access_put_jazz(
