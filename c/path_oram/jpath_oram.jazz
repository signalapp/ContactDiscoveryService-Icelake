/* struct oram layout functions - these are the source of truth */
export
fn oram_sizeof_jazz() -> reg u64
{
  reg u64 r;
  r = PathORAM::ORAM_NUM_U64S * 8;
  return r;
}

export
fn oram_bucket_store_offset_jazz() -> reg u64
