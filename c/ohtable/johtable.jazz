from UTIL require "types.jinc"
require "ohtable.jinc"

/* struct ohtable layout functions - Jasmin only accesses some fields */
export fn ohtable_sizeof_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::OHTABLE_NUM_U64S * 8;
  return r;
}

export fn ohtable_capacity_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::CAPACITY * 8;
  return r;
}

export fn ohtable_items_per_block_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::ITEMS_PER_BLOCK * 8;
  return r;
}

export fn ohtable_capacity_ct_m_prime_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::CAPACITY_CT_M_PRIME * 8;
  return r;
}

export fn ohtable_capacity_ct_shift1_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::CAPACITY_CT_SHIFT1 * 8;
  return r;
}

export fn ohtable_capacity_ct_shift2_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::CAPACITY_CT_SHIFT2 * 8;
  return r;
}

export fn ohtable_items_per_block_ct_m_prime_offset_jazz() -> reg u64 {
  reg u64 r;
  r = OHTable::ITEMS_PER_BLOCK_CT_M_PRIME * 8;
  return r;
}

export fn ohtable_items_per_block_ct_shift1_offset_jazz() -> reg u64 {
