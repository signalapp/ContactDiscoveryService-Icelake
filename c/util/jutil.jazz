from UTIL require "types.jinc"
from UTIL require "util.jinc"

// Generally useful wrappers exported for C tests and potential reuse.
export
fn floor_log2_jazz(reg u64 n) -> reg u64
{
  n = n;
  n = _floor_log2(n);
  return n;
}

export
fn ceil_log2_jazz(reg u64 n) -> reg u64
{
  n = n;
  n = _ceil_log2(n);
  return n;
}
